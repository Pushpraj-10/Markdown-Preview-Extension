{
  "name": "markview-renderer",
  "displayName": "MarkView-Renderer",
  "description": "A beautiful GitHub-style Markdown viewer and editor for Visual Studio Code.",
  "version": "0.1.0",
  "publisher": "pushpraj-10",
  "license": "MIT",
  "icon": "images/Logo.png",
  "preview": false,
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "markdown",
    "readme",
    "preview",
    "viewer",
    "github",
    "documentation",
    "editor",
    "md"
  ],
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pushpraj-10/MarkView"
  },
  "homepage": "https://github.com/Pushpraj-10/MarkView#readme",
  "bugs": {
    "url": "https://github.com/Pushpraj-10/MarkView/issues"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onCustomEditor:githubMarkdown.markdownEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "githubMarkdown.markdownEditor",
        "displayName": "MarkView",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.cjs",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.cjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.cjs --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "marked": "^18.0.5"
  }
}